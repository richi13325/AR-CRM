# CRM2 backend — environment variables template
# Copy this file to ".env" and fill in real values.
# ".env" is git-ignored; never commit it.

# ---------------------------------------------------------------------------
# Keycloak admin client (used by the boot app's WebClient to call
# /admin/realms/{realm}/users, reset-password, send-verify-email, etc.)
# MUST match the `secret` value of the `crm2-api` client in
# Keycloak/realm-export.json. The default in the exported realm is:
KEYCLOAK_ADMIN_SECRET=crm2-api-secret-local

# ---------------------------------------------------------------------------
# Outbound mail (SMTP) — used by the reminder job and identity-provisioning
# verification emails (which Keycloak itself sends via its realm SMTP config;
# see Keycloak/README.md).
# For local dev with a dummy SMTP catcher, these can be left blank and
# Keycloak SMTP can point to maildev / smtp4dev on host.docker.internal.
CRM2_NOTIFICATION_MAIL_USERNAME=
CRM2_NOTIFICATION_MAIL_PASSWORD=
CRM2_MAIL_FROM_ADDRESS=

# ---------------------------------------------------------------------------
# WhatsApp / Evolution API
# EVOLUTION_API_URL / EVOLUTION_API_KEY: instancia de Evolution API (credenciales
# globales por defecto; cada canal puede sobrescribirlas al crearse).
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
# WA_WEBHOOK_API_KEY: clave que Evolution/n8n manda en el header x-api-key al
# webhook entrante. Poné un secreto fuerte en prod.
WA_WEBHOOK_API_KEY=change-me-in-prod
# WA_WEBHOOK_BASE_URL: URL PÚBLICA de ESTE backend para que Evolution pueda
# alcanzarlo y mandar los mensajes entrantes EN VIVO (ej. https://api.tudominio.com).
# CRÍTICO: si queda vacía, el webhook NUNCA se registra en Evolution y NO llegan
# mensajes nuevos (ni preview, ni badge de no leídos). En dev local sin túnel
# público, dejarla vacía y usar el "sync historial" manual.
WA_WEBHOOK_BASE_URL=

# ---------------------------------------------------------------------------
# IA: sugerencia de respuesta en el chat (Claude / Anthropic).
# Sin esta clave, el botón de "sugerir respuesta" devuelve error (el resto del CRM
# funciona igual). ANTHROPIC_MODEL es opcional (default claude-haiku-4-5).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
